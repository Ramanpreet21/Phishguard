# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Environments ────────────────────────────────────────────────
.env
.venv/
venv/
env/

# ── Trained model artifacts ─────────────────────────────────────
src/models/artifacts/*.pkl
src/models/artifacts/*.pt
!src/models/artifacts/.gitkeep

# ── Datasets (too large for git) ────────────────────────────────
data/*.csv
data/*.arff
data/*.zip

# ── Logs ────────────────────────────────────────────────────────
logs/*.jsonl
logs/*.log
!logs/.gitkeep

# ── Benchmark reports ────────────────────────────────────────────
benchmark_report.json

# ── Visualisations ───────────────────────────────────────────────
*.png

# ── IDE ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
