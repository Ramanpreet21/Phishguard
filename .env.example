# ─── PhishGuard Configuration ──────────────────────────────────
# Copy this file to .env and adjust values as needed.
# All values shown are defaults — only set what you want to override.

# ── Paths ──────────────────────────────────────────────────────
# ARTIFACTS_DIR=src/models/artifacts
# LOGS_DIR=logs
# DATA_DIR=data

# ── API Server ─────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
# PREDICTOR_DEVICE=cpu
# WORKERS=1

# ── Model Thresholds ──────────────────────────────────────────
# SAFE_CEILING=0.35
# PHISHING_FLOOR=0.65
# CONFLICT_THRESHOLD=0.40

# ── Training Hyperparameters ──────────────────────────────────
# RF_N_ESTIMATORS=200
# RF_MAX_DEPTH=25
# XGB_N_ESTIMATORS=200
# SVM_C=1.0
# RANDOM_SEED=42
# DL_EPOCHS=10
# DL_BATCH_SIZE=256
# DL_LEARNING_RATE=0.0003

# ── Feature Extraction ───────────────────────────────────────
# EXTRACTION_WORKERS=4
# EXTRACTION_BATCH_SIZE=5000
